{% extends "base.html.j2" %}
{% block content %}
<h1>Configuration</h1>
{% if vm.saved %}
  <div class="banner success">Saved.</div>
{% endif %}
{% if vm.risk_policy_divergence %}
  <div class="banner warning" style="background:#fff3cd;border:1px solid #ffeeba;padding:0.75rem;margin:0.5rem 0;color:#856404;">
    <strong>TOML divergence:</strong>
    <code>cfg.account.risk_equity_floor = {{ vm.risk_policy_divergence.toml_value }}</code>
    differs from
    <code>risk_policy.capital_floor_constant_dollars = {{ vm.risk_policy_divergence.policy_value }}</code>.
    risk_policy is authoritative; the displayed value above reflects the TOML edit.
    To make TOML canonical, run
    <code>swing config policy import-from-toml --field capital_floor_constant_dollars</code>.
  </div>
{% endif %}
<form method="post" action="/config" id="config-form"
      hx-post="/config" hx-target="#config-form-result" hx-swap="innerHTML"
      hx-headers='{"HX-Request": "true"}'>
  {% for row in vm.rows %}
    {% if row.input_kind in ('int', 'float') %}
      <div class="config-row">
        <label for="{{ row.path }}">
          {{ row.label }}
          <small class="muted">({{ row.path }})</small>
        </label>
        <p class="description">{{ row.description }}</p>
        <input
          type="number"
          id="{{ row.path }}"
          name="{{ row.path }}"
          value="{{ row.current_value }}"
          {% if row.input_kind == 'int' %}step="1"{% else %}step="0.001"{% endif %}
        />
        <span class="default-value">default: {{ row.default_value }}</span>
        <span class="source-badge source-{{ row.source }}">{{ row.source }}</span>
      </div>
    {% else %}
      {# Sub-bundle A T-A.2 — masked/display-only rows (e.g. Schwab account
         hash) render as a read-only summary; not POSTable via /config. #}
      <div class="config-row config-row-readonly">
        <label>
          {{ row.label }}
          <small class="muted">({{ row.path }})</small>
        </label>
        <p class="description">{{ row.description }}</p>
        <span class="display-value">{{ row.current_value }}</span>
        <span class="source-badge source-{{ row.source }}">{{ row.source }}</span>
      </div>
    {% endif %}
  {% endfor %}
  <button type="submit">Save</button>
</form>
<div id="config-form-result"></div>

<section class="config-integrations" style="margin-top:1.5rem;">
  <h2>External integrations</h2>
  <p>
    <a href="/schwab/setup">Set up / re-authorize Schwab OAuth &rarr;</a>
  </p>
  <p class="description">
    Use weekly when the refresh token nears expiration. An existing tokens database (if any) will be safely renamed before a new one is written.
  </p>
</section>

{% for row in vm.rows %}
  {% if row.input_kind in ('int', 'float') %}
    <form method="post" action="/config/reset/{{ row.path }}"
          hx-post="/config/reset/{{ row.path }}"
          hx-headers='{"HX-Request": "true"}'
          class="reset-form">
      <button type="submit" class="reset-btn">Reset {{ row.label }}</button>
    </form>
  {% endif %}
{% endfor %}
{% endblock %}
