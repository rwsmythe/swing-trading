{# Phase 14 SB4 Slice 3 (OQ-9) — the journal listing <table>, extracted so the
   SAME include serves BOTH the full page (journal.html.j2) AND the HX sort/filter
   fragment (routes/journal.py HX branch). Hand-duplicating this markup would
   silently drift (the OOB-drift gotcha) — keep this the single source.

   The fragment ROOT is `<table id="journal-table">` (NOT a bare <tr>), so the
   HTMX synthetic-table-wrap (makeFragment) cannot fire on an outerHTML swap.

   Query-state preservation (WP-R2 M#5): every sort control URL is built from the
   FULL current query state (vm.query_state) overriding only `sort`/`dir`, so a
   sort click NEVER drops the active filters. `_filters` holds the carry-over
   filter querystring (period + any active filter_*); each sort link appends its
   own sort/dir on top.

   ALL operator/derived text is auto-escaped (NO `| safe`). #}
{%- set _q = vm.query_state -%}
{%- set _filters -%}
period={{ _q.period }}
{%- if _q.filter_state %}&filter_state={{ _q.filter_state }}{% endif -%}
{%- if _q.filter_pattern %}&filter_pattern={{ _q.filter_pattern }}{% endif -%}
{%- if _q.filter_aplus %}&filter_aplus={{ _q.filter_aplus }}{% endif -%}
{%- endset -%}
{# A sort header cell: clicking flips to `dir` for `key`, carrying all filters. #}
{%- macro sort_th(label, key) -%}
  {%- set _dir = 'asc' if (_q.sort == key and _q.dir == 'desc') else 'desc' -%}
  <th><a hx-get="/journal?{{ _filters }}&sort={{ key }}&dir={{ _dir }}"
       hx-target="#journal-table" hx-swap="outerHTML"
       hx-headers='{"HX-Request": "true"}'>{{ label }}{% if _q.sort == key %} {{ 'v' if _q.dir == 'desc' else '^' }}{% endif %}</a></th>
{%- endmacro -%}
{# GAP #1 — filter <select> controls. The control row lives INSIDE the
   <table> (a <thead> row whose <th colspan> hosts a <form>), so the fragment
   ROOT stays `<table id="journal-table">` (OQ-9). Because the whole table —
   controls included — is replaced on every outerHTML swap, each select's
   active value is re-marked `selected` from vm.filter_*, so selections persist
   across sort/filter swaps. Hidden inputs carry the active period/sort/dir so a
   filter change (hx-include="closest form") does NOT drop the active sort.
   Allowlist-only option values; all text auto-escaped (NO `| safe`). #}
{%- set _state_options = [
  ('open', 'Open'), ('closed_any', 'Closed (any)'), ('entered', 'Entered'),
  ('managing', 'Managing'), ('partial_exited', 'Partial exited'),
  ('closed', 'Closed'), ('reviewed', 'Reviewed')] -%}
{%- set _pattern_options = [
  ('vcp', 'VCP'), ('flat_base', 'Flat base'),
  ('cup_with_handle', 'Cup with handle'), ('high_tight_flag', 'High tight flag'),
  ('double_bottom_w', 'Double bottom (W)')] -%}
{%- set _aplus_options = [('aplus', 'A+'), ('non_aplus', 'Non-A+')] -%}
<table id="journal-table">
  {% if vm.invalid_filter %}
  <caption class="invalid-filter-notice">Invalid filter, showing all.</caption>
  {% endif %}
  <thead>
    <tr class="journal-filter-row">
      <th colspan="12">
        <form class="journal-filters">
          {# Hidden inputs preserve the active period + sort/dir so an
             hx-include="closest form" on a filter change carries them. #}
          <input type="hidden" name="period" value="{{ _q.period }}">
          {% if _q.sort %}<input type="hidden" name="sort" value="{{ _q.sort }}">{% endif %}
          {% if _q.dir %}<input type="hidden" name="dir" value="{{ _q.dir }}">{% endif %}
          <label>State
            <select name="filter_state"
                    hx-get="/journal" hx-target="#journal-table"
                    hx-swap="outerHTML" hx-trigger="change"
                    hx-include="closest form"
                    hx-headers='{"HX-Request": "true"}'>
              <option value="">All</option>
              {% for value, label in _state_options %}
              <option value="{{ value }}"{% if vm.filter_state == value %} selected{% endif %}>{{ label }}</option>
              {% endfor %}
            </select>
          </label>
          <label>Pattern
            <select name="filter_pattern"
                    hx-get="/journal" hx-target="#journal-table"
                    hx-swap="outerHTML" hx-trigger="change"
                    hx-include="closest form"
                    hx-headers='{"HX-Request": "true"}'>
              <option value="">All</option>
              {% for value, label in _pattern_options %}
              <option value="{{ value }}"{% if vm.filter_pattern == value %} selected{% endif %}>{{ label }}</option>
              {% endfor %}
            </select>
          </label>
          <label>A+
            <select name="filter_aplus"
                    hx-get="/journal" hx-target="#journal-table"
                    hx-swap="outerHTML" hx-trigger="change"
                    hx-include="closest form"
                    hx-headers='{"HX-Request": "true"}'>
              <option value="">All</option>
              {% for value, label in _aplus_options %}
              <option value="{{ value }}"{% if vm.filter_aplus == value %} selected{% endif %}>{{ label }}</option>
              {% endfor %}
            </select>
          </label>
        </form>
      </th>
    </tr>
      <th>Chart</th>
      {{ sort_th('Ticker', 'ticker') }}
      {{ sort_th('Entry', 'entry_date') }}
      {{ sort_th('State', 'state') }}
      <th>Open price</th>
      <th>Shares</th>
      {{ sort_th('Total risk', 'total_risk_dollars') }}
      <th>Closing price</th>
      {{ sort_th('Final R', 'final_r') }}
      <th>Pattern</th>
      <th>A+ bucket</th>
      <th>Hypothesis</th>
    </tr>
  </thead>
  <tbody>
    {% for row in vm.rows %}
      {% include "partials/journal_row.html.j2" %}
    {% else %}
      <tr><td colspan="12">No trades in this period.</td></tr>
    {% endfor %}
  </tbody>
</table>
