{#- Trade entry form — swaps into a watchlist row.

    Phase 7 Sub-C C.4: 7 sectioned <fieldset> blocks per spec §11.1
    (single-page; no JS accordion; operator scrolls). Field-level error
    markers driven by `vm.missing_fields` (frozenset[str]); draft
    preservation via `vm.draft_*` fields populated by the route's
    MissingPreTradeFieldsException catch path.

    Expects:
      - vm (TradeEntryFormVM) — REQUIRED
      - error_message (optional str) — banner displayed at top of form td
-#}
{%- macro err_class(name) -%}
{% if name in vm.missing_fields %} class="field-error"{% endif %}
{%- endmacro -%}
<tr id="entry-form-{{ vm.ticker }}">
  <td colspan="{{ 9 if vm.origin == 'hyp-recs' else 8 }}">
    {% if error_message %}<div class="banner banner-degraded" role="alert">{{ error_message }}</div>{% endif %}
    {#- Phase 13 T3.SB1 — Schwab entry auto-fill advisory + display-only
        audit metadata (spec §6.1 + plan §G.2 T-B.1.3). The banner renders
        when auto_fill_advisory_text is set (sandbox / degraded / error /
        empty kinds — all use this surface to inform the operator).
        Populated kind has advisory_text=None — operator sees pre-filled
        inputs with no banner. -#}
    {% if vm.auto_fill_advisory_text %}
    <div class="banner banner-info" role="status">
      <strong>Schwab auto-fill:</strong> {{ vm.auto_fill_advisory_text }}
    </div>
    {% endif %}
    {% if vm.auto_fill_kind == 'populated' %}
    <div class="auto-fill-audit">
      <label>Auto-fill source:</label>
      <span class="muted">{{ vm.auto_fill_fill_origin }}
        (Schwab Trader API; recorded at <time>{{ vm.auto_fill_audit_at }}</time>)
      </span>
    </div>
    {% endif %}
    <form hx-post="/trades/entry"
          hx-target="closest tr" hx-swap="outerHTML"
          hx-headers='{"HX-Request": "true"}'>
      <input type="hidden" name="ticker" value="{{ vm.ticker }}">
      <input type="hidden" name="origin" value="{{ vm.origin }}">
      {#- Phase 13 T3.SB1 — auto-fill hidden anchors (T-B.1.3).
          ``schwab_source_value_json`` carries the SERVER-STAMPED original
          auto-populated values as a JSON envelope; the POST handler
          compares submitted entry_date/entry_price/shares against this
          to detect operator edits + flip fill_origin to
          'schwab_auto_then_operator_corrected'. Per CLAUDE.md gotcha
          "For any V1 single-operator form with hidden audit fields,
          default to SERVER-STAMPING at handler entry" — the GET handler
          server-stamps these; the operator sees them as display-only
          metadata above. The hidden inputs carry the values to POST
          (transport requirement; without them POST cannot detect edits).
          Per Phase 9 Sub-bundle D R3 Critical #1, these hidden anchors
          MUST round-trip through the soft-warn confirm ``form_values``
          dict (T-B.1.5 handles). -#}
      {% if vm.auto_fill_schwab_source_value_json %}
      <input type="hidden" name="schwab_source_value_json"
             value="{{ vm.auto_fill_schwab_source_value_json }}">
      <input type="hidden" name="auto_fill_audit_at"
             value="{{ vm.auto_fill_audit_at }}">
      <input type="hidden" name="fill_origin_at_form_render"
             value="{{ vm.auto_fill_fill_origin }}">
      {% endif %}

      {#- §1 Position basics -#}
      <fieldset class="entry-section entry-section-position-basics">
        <legend>Position basics</legend>
        <div><label>Ticker</label>
          <span>{{ vm.ticker }}</span></div>
        <div><label>Entry date</label>
          <input type="date" name="entry_date" value="{{ vm.entry_date }}" required></div>
        <div><label>Entry price</label>
          <input type="number" step="0.01" min="0" name="entry_price"
                 value="{{ '%.2f' | format(vm.entry_price) }}" required></div>
        <div><label>Shares</label>
          <input type="number" step="1" min="1" name="shares"
                 value="{{ vm.input_shares if vm.input_shares else vm.suggested_shares }}" required>
          <span id="sizing-hint"
                hx-get="/trades/entry/sizing-hint"
                hx-trigger="change from:input[name=entry_price],input[name=initial_stop] delay:200ms"
                hx-include="closest form"
                hx-target="this"
                hx-swap="outerHTML">
            {% if vm.suggested_shares > 0 %}
              Suggested max: <strong>{{ vm.suggested_shares }} sh</strong>
              (~${{ '%.2f' | format(vm.risk_dollars) }} risk =
              {{ '%.2f' | format(vm.risk_pct) }}%)
            {% else %}
              <span class="subtitle">Enter a valid entry price and stop to see sizing</span>
            {% endif %}
          </span></div>
        <div><label>Initial stop</label>
          <input type="number" step="0.01" min="0" name="initial_stop"
                 value="{{ '%.2f' | format(vm.initial_stop) }}" required></div>
        {% if vm.watchlist_entry_target is not none %}
        <div><label>Watchlist target</label>
          <input type="hidden" name="watchlist_target" value="{{ vm.watchlist_entry_target }}">
          <span>${{ '%.2f' | format(vm.watchlist_entry_target) }}</span></div>
        {% endif %}
        {% if vm.watchlist_initial_stop is not none %}
          <input type="hidden" name="watchlist_stop" value="{{ vm.watchlist_initial_stop }}">
        {% endif %}
      </fieldset>

      {#- §2 Setup attribution -#}
      <fieldset class="entry-section entry-section-setup-attribution">
        <legend>Setup attribution</legend>
        {% include "partials/trade_entry_chart_pattern_section.html.j2" %}
        <div><label>Sector:</label>
          <span>{{ vm.sector or "—" }}</span>
          <input type="hidden" name="sector" value="{{ vm.sector }}">
        </div>
        <div><label>Industry:</label>
          <span>{{ vm.industry or "—" }}</span>
          <input type="hidden" name="industry" value="{{ vm.industry }}">
        </div>
        {#- Phase 9 Bundle D — sector/industry tamper-hardening anchor.
            Carries the form-render's evaluation_run_id so POST
            validation reaches the same authoritative candidate row
            the operator saw (Codex R2 Major #1 fix; mirrors
            chart_pattern's pipeline_run_id anchor pattern). Empty value
            when no cached candidate exists at form-render time — POST
            treats absence as the bare-cURL backward-compat skip. -#}
        <input type="hidden" name="sector_industry_evaluation_run_id"
               value="{{ vm.sector_industry_evaluation_run_id
                         if vm.sector_industry_evaluation_run_id is not none
                         else '' }}">
        <div><label>Hypothesis:</label>
          <span>{{ vm.hypothesis_label or "(none)" }}</span>
          <input type="hidden" name="hypothesis_label" value="{{ vm.hypothesis_label or '' }}">
        </div>
        <div><label>Trade origin:</label>
          {#- Display-only; auto-derived in record_entry. The hidden form
              field is intentionally NOT emitted — record_entry derives
              trade_origin from EntryPath + hypothesis_label, so a posted
              value would be silently overridden. Render as <output> for
              accessibility per spec §11.1 (display-only). -#}
          <output class="subtitle">auto-derived</output>
        </div>
        <div><label>Rationale &#9733;</label>
          <select name="rationale" required
                  onchange="var h=this.form.querySelector('.rationale-other-hint'); if(h){h.style.display=(this.value==='other')?'inline':'none';}">
            <option value="">(select one)</option>
            {% for value, label in vm.rationale_options %}
              <option value="{{ value }}"{% if value == vm.rationale %} selected{% endif %}>{{ label }}</option>
            {% endfor %}
          </select></div>
      </fieldset>

      {#- §3 Pre-trade thesis -#}
      <fieldset class="entry-section entry-section-thesis">
        <legend>Pre-trade thesis</legend>
        {#- 3e.7 Task B.1: per-textarea example aside (locked content from
            brief §0.3 #6). Static prompt-style hints — NOT trade-specific,
            NOT toggle-shown. Mirrors operator preference (visible always). -#}
        <div class="entry-textarea-row">
          <div class="entry-textarea">
            <label>Thesis</label>
            <textarea name="thesis"{{ err_class('thesis') }}>{{ vm.draft_thesis }}</textarea>
          </div>
          <aside class="entry-example-aside" aria-label="Examples for pre-trade thesis">
            <details>
              <summary><strong>Examples</strong></summary>
              <ul>
                <li>Setup type + base structure (e.g., VCP with N contractions; cup-with-handle; flat base of length L weeks; depth %).</li>
                <li>Setup grade + binding criteria passed (A+ vs A vs sub-A; which trend-template + VCP criteria are met or relaxed and why the relaxation is acceptable).</li>
                <li>Catalyst + RS context (sector strength + group leaders confirming; earnings driver; macro thesis).</li>
              </ul>
            </details>
          </aside>
        </div>
        <div class="entry-textarea-row">
          <div class="entry-textarea">
            <label>Why now</label>
            <textarea name="why_now"{{ err_class('why_now') }}>{{ vm.draft_why_now }}</textarea>
          </div>
          <aside class="entry-example-aside" aria-label="Examples for why now">
            <details>
              <summary><strong>Examples</strong></summary>
              <ul>
                <li>Trigger event (pivot just printed; base just completed; today's volume signature).</li>
                <li>Window context (days since base formation; setup grade trajectory; freshness of signal).</li>
                <li>Cost of waiting (catalyst date approaching; pivot extending; setup-grade decay risk).</li>
              </ul>
            </details>
          </aside>
        </div>
        <div class="entry-textarea-row">
          <div class="entry-textarea">
            <label>Expected scenario</label>
            <textarea name="expected_scenario"{{ err_class('expected_scenario') }}>{{ vm.draft_expected_scenario }}</textarea>
          </div>
          <aside class="entry-example-aside" aria-label="Examples for expected scenario">
            <details>
              <summary><strong>Examples</strong></summary>
              <ul>
                <li>Pivot holds → first profit zone in N sessions (typical: +5-15% in 1-3 weeks for VCP / cup).</li>
                <li>First +1R checkpoint (price target; expected timing; confirming volume signature).</li>
                <li>Maturity-stage progression (maturing → +1.5R → +2R → trail-MA upgrade per project trade-maturity doctrine).</li>
              </ul>
            </details>
          </aside>
        </div>
        <div class="entry-textarea-row">
          <div class="entry-textarea">
            <label>Invalidation condition</label>
            <textarea name="invalidation_condition"{{ err_class('invalidation_condition') }}>{{ vm.draft_invalidation_condition }}</textarea>
          </div>
          <aside class="entry-example-aside" aria-label="Examples for invalidation condition">
            <details>
              <summary><strong>Examples</strong></summary>
              <ul>
                <li>Hard stop (close below the initial_stop level above; binding numerical exit).</li>
                <li>Soft invalidation (setup degrades pre-stop: violates 20MA on volume; base re-tests pivot 3+ times; volume profile dries up).</li>
                <li>Time-stop (no breakout movement within N sessions — exit at-market regardless of stop level).</li>
              </ul>
            </details>
          </aside>
        </div>
      </fieldset>

      {#- §4 Premortem -#}
      <fieldset class="entry-section entry-section-premortem">
        <legend>Premortem</legend>
        <div class="entry-textarea-row">
          <div class="entry-textarea">
            <label>Technical failure mode</label>
            <textarea name="premortem_technical"{{ err_class('premortem_technical') }}>{{ vm.draft_premortem_technical }}</textarea>
          </div>
          <aside class="entry-example-aside" aria-label="Examples for premortem: technical">
            <details>
              <summary><strong>Examples</strong></summary>
              <ul>
                <li>What invalidates the setup (close below pivot; close below 50MA; base breakdown on volume).</li>
                <li>Where the framework would call you wrong (extended above 20MA; tightness floor not met; volume profile thin).</li>
                <li>Failure modes for the specific pattern (VCP final contraction blow-out; cup-with-handle handle too deep; flat-base inside-day reversal).</li>
              </ul>
            </details>
          </aside>
        </div>
        <div class="entry-textarea-row">
          <div class="entry-textarea">
            <label>Market / sector failure mode</label>
            <textarea name="premortem_market_sector"{{ err_class('premortem_market_sector') }}>{{ vm.draft_premortem_market_sector }}</textarea>
          </div>
          <aside class="entry-example-aside" aria-label="Examples for premortem: market/sector">
            <details>
              <summary><strong>Examples</strong></summary>
              <ul>
                <li>Market weather state + your sizing response (bullish / caution / bearish; full / half / skip).</li>
                <li>Sector strength vs market (RS rank; leadership concentration; mean-reversion risk).</li>
                <li>Macro/news risk specific to the trade window (scheduled FOMC / CPI / earnings; sector-specific catalysts pending).</li>
              </ul>
            </details>
          </aside>
        </div>
        <div class="entry-textarea-row">
          <div class="entry-textarea">
            <label>Execution failure mode</label>
            <textarea name="premortem_execution"{{ err_class('premortem_execution') }}>{{ vm.draft_premortem_execution }}</textarea>
          </div>
          <aside class="entry-example-aside" aria-label="Examples for premortem: execution">
            <details>
              <summary><strong>Examples</strong></summary>
              <ul>
                <li>Personal entry biases (chase tendency; premature add; sizing inconsistency).</li>
                <li>Stop discipline (no tightening before +1.5R; trail-MA selection per trade-maturity stage).</li>
                <li>Position management (drawdown to half-stop response; breakout-and-fade response).</li>
              </ul>
            </details>
          </aside>
        </div>
        <div class="entry-textarea-row">
          <div class="entry-textarea">
            <label>Additional risks (optional)</label>
            <textarea name="premortem_additional">{{ vm.draft_premortem_additional }}</textarea>
          </div>
          <aside class="entry-example-aside" aria-label="Examples for premortem: additional">
            <details>
              <summary><strong>Examples</strong></summary>
              <ul>
                <li>Earnings proximity + hold-through policy (distance in sessions; sizing / exit policy).</li>
                <li>Personal availability (travel; workload conflicts; ability to manage in-flight).</li>
                <li>Catch-all for pattern-specific or ticker-specific risks not covered above.</li>
              </ul>
            </details>
          </aside>
        </div>
      </fieldset>

      {#- §5 Risk acknowledgments. V1: always-visible if-then conditional
          inputs (no HTMX progressive disclosure; that's V2). The validator's
          conditional rule fires if event_risk_present=1 with empty
          event_handling/event_type/event_date.

          event_risk_present / gap_risk_present rendered as a No/Yes radio
          pair (NOT a bare checkbox) so the form always posts a value
          when the operator has made a selection — bare-checkbox semantics
          (no key sent when unchecked) collide with the validator's
          required-field check (None == missing). Operator MUST pick one;
          un-picked = validator-rejected (per spec §3.5.1). -#}
      <fieldset class="entry-section entry-section-risk">
        <legend>Risk acknowledgments</legend>
        <div><label>Event risk present</label>
          <label><input type="radio" name="event_risk_present" value="0"
                        {% if vm.draft_event_risk_present == 0 %}checked{% endif %}>
            No</label>
          <label><input type="radio" name="event_risk_present" value="1"
                        {% if vm.draft_event_risk_present == 1 %}checked{% endif %}>
            Yes</label>
          {% if 'event_risk_present' in vm.missing_fields %}
            <span class="field-error subtitle">required</span>
          {% endif %}
        </div>
        <div><label>Event handling</label>
          <select name="event_handling"{{ err_class('event_handling') }}>
            <option value="">(none)</option>
            {% for value in ('avoid_event', 'hold_through', 'reduce_before', 'exit_before', 'not_applicable') %}
              <option value="{{ value }}"{% if vm.draft_event_handling == value %} selected{% endif %}>{{ value }}</option>
            {% endfor %}
          </select></div>
        <div><label>Event type</label>
          <select name="event_type"{{ err_class('event_type') }}>
            <option value="">(none)</option>
            {% for value in ('earnings', 'fed_meeting', 'cpi_release', 'economic_data', 'product_announcement', 'legal_ruling', 'other') %}
              <option value="{{ value }}"{% if vm.draft_event_type == value %} selected{% endif %}>{{ value }}</option>
            {% endfor %}
          </select></div>
        <div><label>Event date</label>
          <input type="date" name="event_date" value="{{ vm.draft_event_date }}"{{ err_class('event_date') }}></div>
        <div><label>Gap risk present</label>
          <label><input type="radio" name="gap_risk_present" value="0"
                        {% if vm.draft_gap_risk_present == 0 %}checked{% endif %}>
            No</label>
          <label><input type="radio" name="gap_risk_present" value="1"
                        {% if vm.draft_gap_risk_present == 1 %}checked{% endif %}>
            Yes</label>
          {% if 'gap_risk_present' in vm.missing_fields %}
            <span class="field-error subtitle">required</span>
          {% endif %}
        </div>
        <div><label>Gap risk handling</label>
          <select name="gap_risk_handling"{{ err_class('gap_risk_handling') }}>
            <option value="">(none)</option>
            {% for value in ('accept', 'reduce_size', 'tight_stop', 'exit_before_close', 'not_applicable') %}
              <option value="{{ value }}"{% if vm.draft_gap_risk_handling == value %} selected{% endif %}>{{ value }}</option>
            {% endfor %}
          </select></div>
      </fieldset>

      {#- §6 Operator state -#}
      <fieldset class="entry-section entry-section-operator-state">
        <legend>Operator state</legend>
        <div><label>Pre-trade emotional state (multi-select)</label>
          {% for value in ('calm', 'confident', 'anxious', 'fomo', 'revenge', 'hopeful', 'doubtful', 'distracted') %}
            <label><input type="checkbox" name="emotional_state_pre_trade" value="{{ value }}"
                          {% if value in vm.draft_emotional_state_pre_trade %}checked{% endif %}>
              {{ value }}</label>
          {% endfor %}
          {% if 'emotional_state_pre_trade' in vm.missing_fields %}
            <span class="field-error subtitle">required</span>
          {% endif %}
        </div>
        <div><label>Manual entry confidence</label>
          {% for value in ('high', 'normal', 'low') %}
            <label><input type="radio" name="manual_entry_confidence" value="{{ value }}"
                          {% if vm.draft_manual_entry_confidence == value %}checked{% endif %}>
              {{ value }}</label>
          {% endfor %}
          {% if 'manual_entry_confidence' in vm.missing_fields %}
            <span class="field-error subtitle">required</span>
          {% endif %}
        </div>
        <div><label>Market regime</label>
          {% for value in ('Bullish', 'Caution', 'Bearish') %}
            <label><input type="radio" name="market_regime" value="{{ value }}"
                          {% if vm.draft_market_regime == value %}checked{% endif %}>
              {{ value }}</label>
          {% endfor %}
          {% if 'market_regime' in vm.missing_fields %}
            <span class="field-error subtitle">required</span>
          {% endif %}
        </div>
        <div><label>Catalyst</label>
          <select name="catalyst"{{ err_class('catalyst') }}>
            <option value="">(select one)</option>
            {% for value in ('technical_only', 'earnings_driven', 'guidance_change', 'corporate_action', 'sector_rotation', 'macro_event', 'sympathy_move', 'product_news', 'other') %}
              <option value="{{ value }}"{% if vm.draft_catalyst == value %} selected{% endif %}>{{ value }}</option>
            {% endfor %}
          </select></div>
        <div><label>Catalyst details (required if catalyst = other)</label>
          <input type="text" name="catalyst_other_description"
                 value="{{ vm.draft_catalyst_other_description }}"{{ err_class('catalyst_other_description') }}></div>
      </fieldset>

      {#- §7 Notes -#}
      <fieldset class="entry-section entry-section-notes">
        <legend>Notes</legend>
        <div><label>Notes
            <span class="rationale-other-hint subtitle"
                  style="display:{% if vm.rationale == 'other' %}inline{% else %}none{% endif %}">
              &#9733; required when Rationale = Other
            </span>
          </label>
          <textarea name="notes">{{ vm.notes }}</textarea></div>
      </fieldset>

      {% if vm.origin == 'hyp-recs' and vm.pipeline_finished_at %}
        <p class="freshness muted">
          Candidate context as of pipeline finished {{ vm.pipeline_finished_at }}
        </p>
      {% endif %}
      <div>
        <button type="submit">Submit</button>
        <button type="button"
                hx-get="{{ '/hyp-recs/refresh' if vm.origin == 'hyp-recs' else '/watchlist/' ~ vm.ticker ~ '/expand' }}"
                hx-target="{{ '#hypothesis-recommendations' if vm.origin == 'hyp-recs' else 'closest tr' }}"
                hx-swap="outerHTML"
                hx-headers='{"HX-Request": "true"}'>Cancel</button>
      </div>
    </form>
  </td>
</tr>
