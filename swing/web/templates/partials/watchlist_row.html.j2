{#- Expects: w (WatchlistEntry), price (PriceSnapshot|None), tags (tuple[str]),
              pattern_tag (str|None — Phase 4 Task 4.7; spec §3.5 SIBLING to tags),
              chart_svg_bytes_for_row (bytes|None — the only supported source
              of the row's thumbnail SVG).

   Phase 13 T-T4.SB.5 Item 6 Option 6B LOCK — `chart_svg_bytes_for_row` is
   the SOLE source of thumbnail bytes; the prior fallback to an enclosing
   `vm` cache map is REMOVED. All three render sites pass the param:
     - watchlist.html.j2 → `{% set chart_svg_bytes_for_row = vm-map.get(...) %}`
     - partials/watchlist_top5_section.html.j2 → same `{% set %}` pattern
     - /watchlist/{ticker}/row route → passes via TemplateResponse context
       (JIT cache lookup at swing/web/routes/watchlist.py:watchlist_row).
   When absent the thumbnail cell renders empty (no fallback). -#}
{% set _thumb_bytes = chart_svg_bytes_for_row if chart_svg_bytes_for_row is defined and chart_svg_bytes_for_row else None %}
<tr id="watchlist-row-{{ w.ticker }}"
    hx-get="/watchlist/{{ w.ticker }}/expand" hx-swap="outerHTML"
    hx-headers='{"HX-Request": "true"}'>
  <td>
    {# Phase 13 T-T4.SB.5 Item 4: lightning glyph removed per operator
       OQ-X.1 LOCK. Thumbnail cell preserved. #}
    {% if _thumb_bytes %}
      <span class="watchlist-thumbnail">{{ _thumb_bytes.decode('utf-8') | safe }}</span>
    {% endif %}
  </td>
  <td>{{ w.ticker }}{% if w.pinned %}<span class="watchlist-pin-badge" title="{{ (w.pin_note or '')|truncate(60) }}">&#x1F4CC;</span>{% endif %}</td>
  <td>
    {% if price %}
      ${{ '%.2f' | format(price.price) }}
      {% if price.is_stale %}<span class="stale">(stale)</span>{% endif %}
    {% else %}—{% endif %}
  </td>
  <td>{% if current_pivot is not none %}${{ '%.2f' | format(current_pivot) }}{% elif w.entry_target %}${{ '%.2f' | format(w.entry_target) }}{% else %}—{% endif %}</td>
  <td>
    {% if price and w.entry_target %}
      {{ '%.1f' | format(((price.price - w.entry_target) / w.entry_target) * 100) }}%
    {% else %}—{% endif %}
  </td>
  <td>{{ '%.2f' | format(w.last_adr_pct or 0) }}</td>
  <td>
    {{ tags | join(' · ') }}
    {%- if pattern_tag is defined and pattern_tag %}
      {%- if tags %} · {% endif -%}
      <span class="tag tag-pattern">{{ pattern_tag }}</span>
    {%- endif %}
    {%- if cohort_hint is defined and cohort_hint %}
      <span class="tag tag-cohort">{{ cohort_hint }}</span>
    {%- endif %}
  </td>
  <td>
    <button onclick="event.stopPropagation()"
            hx-get="/trades/entry/form?ticker={{ w.ticker }}"
            hx-target="closest tr" hx-swap="outerHTML"
            hx-headers='{"HX-Request": "true"}'>Enter</button>
  </td>
</tr>
