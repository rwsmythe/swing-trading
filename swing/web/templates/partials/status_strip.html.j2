{#- status_strip — three tiles + run-now button -#}
<div class="tile" id="weather-tile">
  <div class="label">Weather</div>
  <div class="value">{{ vm.status_strip.weather_status }}</div>
  <div class="rationale">{{ vm.status_strip.weather_rationale }}</div>
</div>
<div class="tile" id="account-tile">
  <div class="label">Account</div>
  <div class="value">${{ '%.0f' | format(vm.status_strip.equity) }}</div>
  {# Arc 4b - secondary Schwab NLV line + cash-coherence badge (DashboardVM-only). #}
  {% if vm.status_strip.schwab_nlv is not none %}
    <div class="schwab-nlv">
      Schwab NLV ${{ '%.2f' | format(vm.status_strip.schwab_nlv) }}
      {%- if vm.status_strip.schwab_nlv_date %} ({{ vm.status_strip.schwab_nlv_date[5:] }}){%- endif %}
    </div>
  {% else %}
    <div class="schwab-nlv muted">Schwab NLV: no snapshot</div>
  {% endif %}
  {% if vm.cash_coherence_badge %}
    <div class="cash-coherence-badge">
      {%- if vm.cash_badge_link_path %}
      <a href="{{ vm.cash_badge_link_path }}">&#9888; cash review</a>
      {%- else %}
      <span>&#9888; cash review</span>
      {%- endif %}
    </div>
  {% endif %}
  <div class="rationale">
    {{ vm.status_strip.open_count }} / {{ vm.status_strip.soft_warn }}
    (hard cap {{ vm.status_strip.hard_cap }})
  </div>
  {% if vm.status_strip.unrealized_pnl is not none %}
    <div class="unrealized">
      Unrealized: ${{ '%.2f' | format(vm.status_strip.unrealized_pnl) }}
      {%- if vm.status_strip.unrealized_priced_count < vm.status_strip.open_count %}
        ({{ vm.status_strip.unrealized_priced_count }} of {{ vm.status_strip.open_count }} priced)
      {%- endif %}
    </div>
  {% endif %}
</div>
<div class="tile" id="open-risk-tile">
  <div class="label">Open risk</div>
  <div class="value">
    ${{ '%.0f' | format(vm.status_strip.open_risk_dollars) }}
    {%- if vm.status_strip.open_risk_pct is none %}
      (—)
    {%- else %}
      ({{ '%.2f' | format(vm.status_strip.open_risk_pct * 100) }}%)
    {%- endif %}
  </div>
  <div class="rationale">
    {{ vm.status_strip.open_risk_position_count }}
    {%- if vm.status_strip.open_risk_position_count == 1 %} position{%- else %} positions{%- endif %}
    {%- if vm.status_strip.open_risk_all_above_breakeven %} (all above breakeven){%- endif %}
  </div>
</div>
<div class="tile" id="pipeline-tile">
  <div class="label">Last pipeline</div>
  <div class="value">{{ vm.status_strip.last_pipeline_ts or "never" }}</div>
  <div class="rationale">
    state: {{ vm.status_strip.last_pipeline_state or "—" }}
    <button hx-post="/pipeline/run" hx-target="#run-panel"
            hx-swap="innerHTML" hx-headers='{"HX-Request": "true"}'>
      Run now
    </button>
  </div>
</div>
<div id="run-panel"></div>
