{# Phase 6 review form. <form>-rooted (NOT <tr>-rooted); leading-<tr> would
   trigger htmx.js makeFragment table-wrap pathology (CLAUDE.md gotcha,
   2026-04-29). HX-Request header explicitly propagated for OriginGuard
   strict-mode (brief §6.2 watch item 6). #}
{% if error_message %}
<p class="form-error" role="alert">{{ error_message }}</p>
{% endif %}
<form method="post" action="/trades/{{ vm.trade.id }}/review"
      hx-post="/trades/{{ vm.trade.id }}/review"
      hx-headers='{"HX-Request": "true"}'>

  {# Phase 13 T3.SB3 (T-B.3.3) — server-stamped audit envelope; operator
     cannot tamper (Phase 8 R2-R5 server-stamping family + L10 LOCK). #}
  <input type="hidden" name="auto_populated_field_keys_json"
         value="{{ vm.auto_populated_field_keys_json or '' }}">

  {% if vm.mfe_pct != 0.0 or vm.mae_pct != 0.0 %}
  <fieldset class="review-auto-fill-mfe-mae" data-role="t-b-3-3-mfe-mae">
    <legend>MFE / MAE since entry (auto-filled from candles)</legend>
    <dl class="mfe-mae-pair">
      <dt>MFE (max favorable excursion)</dt>
      <dd data-field="mfe_pct">{{ "%.2f"|format(vm.mfe_pct * 100) }}%</dd>
      <dt>MAE (max adverse excursion)</dt>
      <dd data-field="mae_pct">{{ "%.2f"|format(vm.mae_pct * 100) }}%</dd>
    </dl>
    <p class="muted">
      Computed against entry price ${{ "%.2f"|format(vm.trade.entry_price) }}
      from Phase 8 daily-management coverage (if present) else OhlcvCache
      daily bars. Display only — operator counterfactuals below remain
      manual.
    </p>
  </fieldset>
  {% endif %}

  {% if vm.priors.process_grade_baseline is not none
        or vm.priors.lesson_learned_candidates
        or vm.priors.mistake_tag_candidates %}
  <fieldset class="review-auto-fill-priors" data-role="t-b-3-3-priors">
    <legend>Priors from recent same-ticker reviews</legend>
    {% if vm.priors.process_grade_baseline is not none %}
    <p data-field="process_grade_baseline">
      Process-grade baseline (mean of recent N grades, A=4..F=0):
      <strong>{{ "%.2f"|format(vm.priors.process_grade_baseline) }}</strong>
    </p>
    {% endif %}
    {% if vm.priors.lesson_learned_candidates %}
    <details data-field="lesson_learned_candidates">
      <summary>
        Lesson-learned candidates (most-recent-first;
        {{ vm.priors.lesson_learned_candidates|length }})
      </summary>
      <ol>
        {% for lesson in vm.priors.lesson_learned_candidates %}
          <li>{{ lesson }}</li>
        {% endfor %}
      </ol>
    </details>
    {% endif %}
    <p class="muted">
      Suggestions only — operator chooses fresh values below. Source:
      same-ticker reviewed trades, ordered most-recent-first.
    </p>
  </fieldset>
  {% endif %}

  <fieldset>
    <legend>Stage grades</legend>
    {% for stage in ["entry", "management", "exit"] %}
      <label>
        {{ stage|capitalize }} grade
        <select name="{{ stage }}_grade" required>
          {% for g in vm.grade_choices %}
            <option value="{{ g }}">{{ g }}</option>
          {% endfor %}
        </select>
      </label>
    {% endfor %}
    <label>
      <input type="checkbox" name="disqualifying_process_violation" value="true">
      Disqualifying process violation occurred (caps grade at D — see below)
    </label>
    <details>
      <summary>v1.2 §9.2 disqualifying violations (reference)</summary>
      <ul>
        {% for v in vm.disqualifying_violations_reference %}
          <li>{{ v }}</li>
        {% endfor %}
      </ul>
    </details>
  </fieldset>

  <fieldset>
    <legend>Mistake tags</legend>
    {% for category, tags in vm.mistake_tag_categories.items() %}
      <p><strong>{{ category|capitalize }}</strong></p>
      {% for tag in tags %}
        <label>
          {# T-B.3.3: pre-check tags surfaced by priors as DEFAULT values
             (§E.4 LOCK; operator-editable). #}
          <input type="checkbox" name="mistake_tags" value="{{ tag }}"
                 {% if tag in vm.priors.mistake_tag_candidates %}checked{% endif %}>
          {{ tag }}
        </label>
      {% endfor %}
    {% endfor %}
  </fieldset>

  <fieldset>
    <legend>Why did this trade fail? (outcome attribution - optional)</legend>
    <label>
      Primary failure mode
      <select name="failure_mode">
        <option value="">- not a loss / not attributed -</option>
        {% for value, label in vm.failure_mode_choices %}
          <option value="{{ value }}">{{ label }}</option>
        {% endfor %}
      </select>
    </label>
    <p><small>Records the proximate cause of the loss for later attribution
       analysis. Separate from process grade (how well you executed) and mistake
       tags (what you did wrong): a clean "good loss" can be an A-grade trade with
       zero mistakes.</small></p>
  </fieldset>

  <fieldset>
    <legend>Design intent (tuition vs error - optional)</legend>
    <label>
      Entry intent
      <select name="entry_intent">
        <option value=""{% if vm.entry_intent_selected is none %} selected{% endif %}>- (unclassified) -</option>
        {% for value, label in vm.entry_intent_choices %}
          <option value="{{ value }}"{% if value == vm.entry_intent_selected %} selected{% endif %}>{{ label }}</option>
        {% endfor %}
      </select>
    </label>
    <p><small>Was this a standard signal-driven entry or a by-design hypothesis
       test? Correct it here if the entry-time classification was wrong; leave
       it unclassified to clear it.</small></p>
  </fieldset>

  <fieldset>
    <legend>Counterfactual (optional)</legend>
    <label>
      Realized R if plan followed
      <input type="number" name="realized_R_if_plan_followed" step="any">
    </label>
    <label>
      Mistake-cost confidence
      <select name="mistake_cost_confidence">
        <option value="">— select —</option>
        <option value="high">High</option>
        <option value="medium">Medium</option>
        <option value="low">Low</option>
      </select>
    </label>
    <p><small>What R would you have realized if you'd followed your original
       plan exactly? Auto-derivation from Fills is a future enhancement; manual entry V1.</small></p>
  </fieldset>

  <fieldset>
    <legend>Lesson learned (required)</legend>
    {# T-B.3.3: pre-fill textarea with the most-recent prior lesson as a
       DEFAULT value (§E.4 LOCK; operator-editable). #}
    <textarea name="lesson_learned" rows="4" required>{%- if vm.priors.lesson_learned_candidates -%}{{ vm.priors.lesson_learned_candidates[0] }}{%- endif -%}</textarea>
  </fieldset>

  <button type="submit">Submit review</button>
</form>
