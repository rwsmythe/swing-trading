{#- Trade stop-adjust form — swaps into an open-position row.
    Expects: vm (TradeStopFormVM), error_message (optional str) -#}
<tr id="stop-form-{{ vm.trade.id }}">
  <td colspan="8">
    {% if error_message %}<div class="banner banner-degraded" role="alert">{{ error_message }}</div>{% endif %}
    <form hx-post="/trades/{{ vm.trade.id }}/stop"
          hx-target="closest tr" hx-swap="outerHTML"
          hx-headers='{"HX-Request": "true"}'>
      <div><label>Trade</label>
        <span>#{{ vm.trade.id }} {{ vm.trade.ticker }} —
              current stop ${{ '%.2f' | format(vm.current_stop) }}</span></div>
      <div><label>New stop</label>
        <input type="number" step="0.01" min="0" name="new_stop"
               value="{{ '%.2f' | format(vm.current_stop) }}" required></div>
      <div><label>Rationale &#9733;</label>
        <select name="rationale" required
                onchange="var h=this.form.querySelector('.rationale-other-hint'); if(h){h.style.display=(this.value==='other')?'inline':'none';}">
          <option value="">(select one)</option>
          {% for value, label in vm.rationale_options %}
            <option value="{{ value }}">{{ label }}</option>
          {% endfor %}
        </select></div>
      <div><label>Notes
          <span class="rationale-other-hint subtitle" style="display:none">
            &#9733; required when Rationale = Other
          </span>
        </label>
        <textarea name="notes"></textarea></div>
      <div>
        <button type="submit">Submit</button>
        <button type="button"
                hx-get="/trades/{{ vm.trade.id }}/cancel"
                hx-target="closest tr" hx-swap="outerHTML"
                hx-headers='{"HX-Request": "true"}'>Cancel</button>
      </div>
    </form>
  </td>
</tr>
