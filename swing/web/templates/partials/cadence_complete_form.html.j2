<form method="post" action="/reviews/{{ vm.review.review_id }}/complete"
      hx-post="/reviews/{{ vm.review.review_id }}/complete"
      hx-headers='{"HX-Request": "true"}'>

  {# Phase 13 T3.SB3 (T-B.3.4 + Codex R1 MAJOR #2 fix) — the audit
     envelope is SERVER-RECOMPUTED at POST time from the canonical
     period helpers (NOT trusted from a hidden form input). Submitting
     a hidden field here would create a tampering surface (Phase 8
     R2-R5 server-stamping gotcha family). The VM still surfaces
     vm.auto_populated_field_keys_json for operator-visible audit
     transparency; the value is intentionally NOT submitted on POST. #}

  {% if vm.period_mistake_tag_aggregate %}
  <fieldset class="period-review-auto-fill-mistakes"
            data-role="t-b-3-4-mistake-aggregate">
    <legend>Most common mistake tags this period</legend>
    <ul>
      {% for tag, count in vm.period_mistake_tag_aggregate.items() %}
      <li>{{ tag }}: {{ count }}</li>
      {% endfor %}
    </ul>
  </fieldset>
  {% endif %}

  {% if vm.period_cohort_health_deltas %}
  <fieldset class="period-review-auto-fill-cohorts"
            data-role="t-b-3-4-cohort-deltas">
    <legend>Cohort health deltas (current vs prior period)</legend>
    <ul>
      {% for cohort, delta in vm.period_cohort_health_deltas.items() %}
      <li>{{ cohort }}: {{ "%+.2f"|format(delta) }} R</li>
      {% endfor %}
    </ul>
  </fieldset>
  {% endif %}

  <label>
    Duration (minutes)
    <input type="number" name="duration_minutes" required min="1">
  </label>
  <label>
    Primary lesson
    {# T-B.3.4: pre-fill with concatenated period-lessons summary as a
       DEFAULT operator-editable starter text (§E.5 LOCK). #}
    <textarea name="primary_lesson" required rows="6">{%- if vm.period_lessons_summary -%}{{ vm.period_lessons_summary }}{%- endif -%}</textarea>
  </label>
  <label>
    Next-period focus
    <textarea name="next_period_focus" required rows="3"></textarea>
  </label>
  <button type="submit">Mark complete + freeze aggregates</button>
</form>
