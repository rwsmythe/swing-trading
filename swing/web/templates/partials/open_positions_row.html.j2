{#- Single open-positions row.
    SINGLE contract: expects `row: OpenPositionsRowVM` with fields
      trade (Trade), price_snapshot (PriceSnapshot|None),
      remaining_shares (int), advisories (tuple[AdvisorySuggestionVM, ...]),
      state_badge_label (str — Phase 7 Sub-C C.2).
    No dual-contract / legacy locals branch. All call sites MUST pass `row`.
    Task 13: Exit button added. Adjust stop button appended in Task 15.
    Tier-2 #3: <tr> carries hx-get='/trades/open/<id>/expand' for click-to-
    expand chart-display; Exit/Adjust buttons need event.stopPropagation()
    so a button click doesn't also fire the row's expand binding (Bug-1
    lesson — see CLAUDE.md HTMX click propagation gotcha).

    Phase 7 Sub-C C.6: state badge rendered next to the ticker via the
    shared partials/state_badge.html.j2 macro (single source of truth —
    pre-empts OOB-swap drift gotcha; this same partial renders both the
    full-page dashboard row and OOB-swap responses for entry POST /
    refresh-now). -#}
{% from "partials/state_badge.html.j2" import render as state_badge %}
<tr id="open-position-{{ row.trade.id }}"
    hx-get="/trades/open/{{ row.trade.id }}/expand"
    hx-target="closest tr"
    hx-swap="outerHTML"
    hx-headers='{"HX-Request": "true"}'>
  <td>{{ row.trade.ticker }} {{ state_badge(row.trade.state) }}
    {% if row.has_update_today %}<span class="badge-update-today" title="daily-management entry recorded for session {{ row.update_session_date }}">✓ logged</span>{% else %}<span class="badge-update-needed" title="no daily-management entry for session {{ row.update_session_date }}">⚠ pending</span>{% endif %}
  </td>
  <td>{{ row.trade.entry_date }}</td>
  <td>${{ '%.2f' | format(row.trade.entry_price) }}</td>
  <td>{{ row.remaining_shares }} / {{ row.trade.initial_shares }}</td>
  <td>${{ '%.2f' | format(row.trade.current_stop) }}</td>
  <td>
    {% if row.price_snapshot %}
      ${{ '%.2f' | format(row.price_snapshot.price) }}
      {% if row.price_snapshot.is_stale %}<span class="stale">(stale)</span>{% endif %}
    {% else %}—{% endif %}
  </td>
  <td>{{ row.trade.sector or "—" }}</td>
  <td>{{ row.trade.industry or "—" }}</td>
  <td>
    {% for s in row.advisories %}
      <div>{{ s.message }}</div>
    {% endfor %}
  </td>
  <td class="row-actions">
    <button onclick="event.stopPropagation()"
            hx-get="/trades/{{ row.trade.id }}/exit/form"
            hx-target="closest tr" hx-swap="outerHTML"
            hx-headers='{"HX-Request": "true"}'>Exit</button>
    <button onclick="event.stopPropagation()"
            hx-get="/trades/{{ row.trade.id }}/stop/form"
            hx-target="closest tr" hx-swap="outerHTML"
            hx-headers='{"HX-Request": "true"}'>Adjust stop</button>
    <a href="/trades/{{ row.trade.id }}"
       class="row-action-link"
       onclick="event.stopPropagation()">Detail</a>
  </td>
</tr>
