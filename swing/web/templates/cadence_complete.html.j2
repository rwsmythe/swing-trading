{% extends "base.html.j2" %}
{% block title %}Complete {{ vm.review.review_type }} review{% endblock %}
{% block content %}
<h1>Complete {{ vm.review.review_type|capitalize }} review</h1>
<p>Period: {{ vm.review.period_start }} – {{ vm.review.period_end }}</p>
<p>{{ vm.n_closed_trades_in_period }} trade{{ "s" if vm.n_closed_trades_in_period != 1 else "" }}
   closed in this period.</p>

<h2>Trade activity during this period</h2>
{% if vm.trades_during_period %}
<ul class="cadence-trade-summary-list">
  {% for row in vm.trades_during_period %}
  <li>
    <span class="trade-summary-tag">{{ row.state_tag }}</span>
    <a href="/trades/{{ row.trade_id }}">{{ row.ticker }}</a>
    {{ row.entry_date }}{% if row.exit_date %} → {{ row.exit_date }}{% endif %}
    ${{ '%.2f' | format(row.entry_price) }}{% if row.exit_price is not none %} → ${{ '%.2f' | format(row.exit_price) }}{% endif %}
    {% if row.realized_R is not none %}{{ '%+.2f' | format(row.realized_R) }}R{% endif %}
    {% if row.hypothesis_label %}<span class="muted">{{ row.hypothesis_label }}</span>{% endif %}
  </li>
  {% endfor %}
</ul>
{% else %}
<p class="muted">No trade activity in this period.</p>
{% endif %}

{# Phase 16 Arc 9 -- watch-standard references (static, pointer-not-fork). #}
{# The standard at docs/research-director-watch-standard.md is the single #}
{# source of truth; this is a per-review-type reminder, not a copy of it. #}
{% if vm.review.review_type == "weekly" %}
<section class="watch-standard-reference">
  <h2>Watch-standard reminder (weekly)</h2>
  <p>Before closing this weekly review, run the weekly glance from the repo root:</p>
  <pre>python scripts/weekly_glance.py</pre>
  <p>Escalate any ATTENTION lines to the research director right away rather than
     waiting for the monthly read.</p>
  <p class="muted">Reference: docs/research-director-watch-standard.md section 2.1
     (the weekly glance).</p>
</section>
{% elif vm.review.review_type == "monthly" %}
<section class="watch-standard-reference">
  <h2>Watch-standard reminder (monthly)</h2>
  <p>The monthly research-director read is due. Every 3rd monthly read is the
     quarterly strategic evaluation.</p>
  <p class="muted">See docs/research-director-watch-standard.md section 3 (the
     monthly read) and section 1 (the cadence / quarterly tier) for the timing
     and what each covers.</p>
</section>
{% endif %}

{% include "partials/cadence_complete_form.html.j2" %}
{% endblock %}
