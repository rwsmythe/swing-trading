{#- swing/web/templates/base.html.j2 -#}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Swing Trading Dashboard</title>
  <script>
    /* 3e.10 dark theme — FOUC-prevention head script.
     *
     * Placed BEFORE the stylesheet link (Codex R1 Major #2 fix) so the
     * `dark` class is on <html> before the browser has fetched and
     * applied app.css — eliminates the theoretical race where a fast-
     * cached stylesheet could compute initial style on the unmodified
     * <html> element. Inline + synchronous; this script always runs
     * before any <body> markup parses.
     *
     * Reads localStorage `swing-trading-theme`; validates the value
     * against the ["light","dark"] allowlist; on "dark", adds the
     * `dark` class to <html>. CSS pairs `html.dark, body.dark` so
     * this head-time class application activates the dark theme
     * cascade before first paint.
     *
     * Untrusted-localStorage hardening: any value other than "dark"
     * or "light" (including null on first visit, or a tampered value)
     * silently falls back to the default light theme. localStorage
     * access is wrapped in try/catch for private-browsing-mode browsers
     * that throw on access.
     *
     * CSP note: this is an inline <script> with no nonce. The project
     * does not currently set a Content-Security-Policy header. If a
     * strict CSP gets introduced (Phase 9+), this script needs to
     * either move to /static/theme-fouc.js with a nonce/hash, or get
     * exempted via 'unsafe-inline'. Documented in dispatch brief §4.2.
     */
    (function () {
      try {
        var t = window.localStorage.getItem('swing-trading-theme');
        /* Explicit allowlist: only "dark" and "light" are recognized.
         * Any other value (null on first visit, tampered, legacy) is
         * silently ignored — default light theme stays applied. */
        if (t === 'dark' || t === 'light') {
          if (t === 'dark') {
            document.documentElement.classList.add('dark');
          }
          /* t === 'light' → no class change; default IS light. */
        }
      } catch (e) {
        /* Private-browsing / storage disabled — fall back to light. */
      }
    })();
  </script>
  <link rel="stylesheet" href="/static/app.css">
  <script src="/static/htmx.min.js"></script>
  <script>
    // Spec 3c §3.2a: HTMX 2.x defaults 4xx responses to swap:false+error:true.
    // Phase 3b+ fragments (trade_form_error, http_error_fragment, csv_upload_error,
    // force_clear_*, stale_run_card) return 400/404/409/413 and MUST swap into
    // the target or the UI silently drops them. Override enables 4xx swapping
    // while keeping the error event for client-side logging.
    htmx.config.responseHandling = [
      {code: "204", swap: false},
      {code: "[12]..", swap: true},
      {code: "[45]..", swap: true, error: true},
    ];
  </script>
</head>
<body>
  <nav class="topbar">
    <span class="date">{{ vm.session_date }}</span>
    <a href="/">Dashboard</a>
    <a href="/watchlist">Watchlist</a>
    <a href="/journal">Journal</a>
    <a href="/reviews/pending">Reviews</a>
    <a href="/pipeline">Pipeline</a>
    <a href="/metrics">Metrics</a>
    <a href="/config">Config</a>
    <button id="theme-toggle"
            class="theme-toggle"
            type="button"
            aria-label="Switch to dark theme">🌙</button>
  </nav>
  {% if vm.stale_banner %}
    {% include "partials/stale_banner.html.j2" %}
  {% endif %}
  {% if vm.price_source_degraded %}
    {% include "partials/price_degraded_banner.html.j2" %}
  {% endif %}
  {% if vm.ohlcv_source_degraded %}
    {% include "partials/ohlcv_degraded_banner.html.j2" %}
  {% endif %}
  {# Phase 10 Sub-bundle E T-E.3 — global reconciliation discrepancy banner.
     Renders when any unresolved-material discrepancies are attributed to
     active or closed trades (orphan-emit discrepancies are out of scope
     per ``swing/metrics/discrepancies.py``'s V1 limitation). #}
  {% if (vm.unresolved_material_discrepancies_count|default(0)) > 0 %}
  <aside class="banner banner-warn"
         data-banner="unresolved-material-discrepancies"
         data-count="{{ vm.unresolved_material_discrepancies_count }}">
    <span class="banner-glyph" aria-hidden="true">⚠</span>
    <strong>{{ vm.unresolved_material_discrepancies_count }} unresolved material reconciliation
      {% if vm.unresolved_material_discrepancies_count == 1 -%}
      discrepancy
      {%- else -%}
      discrepancies
      {%- endif %}.</strong>
    Resolve via <code>swing journal discrepancy</code> CLI.
  </aside>
  {% endif %}
  {# Phase 12.5 #1 Task T-1.9 — multi-leg auto-correction advisory banner.
     Renders when the latest completed reconciliation_run dispatched at
     least one multi-leg tier-1 auto-redirect (resolved_by =
     'auto_tier1_multi_leg'). ASCII-only per F12 LOCK (no em-dash, no
     arrows, no unicode glyphs) -- pre-empts the CLAUDE.md cp1252-stdout
     gotcha family at any future server-rendered surface. CLI command
     rendered verbatim cites the T-1.10 --resolved-by filter (banner +
     filter ship together per spec §8.6 LOCK + plan §D #9). #}
  {% if vm.recent_multi_leg_auto_correction_count > 0 %}
  <div class="reconciliation-auto-redirect-banner" data-banner-count="{{ vm.recent_multi_leg_auto_correction_count }}">
    {{ vm.recent_multi_leg_auto_correction_count }} multi-leg auto-correction{{ 's' if vm.recent_multi_leg_auto_correction_count != 1 else '' }} in most recent reconciliation run. Review via <code>swing journal discrepancy list --resolved-by auto_tier1_multi_leg</code>.
  </div>
  {% endif %}
  <main>
    {% block content %}{% endblock %}
  </main>
  <script>
    /* 3e.10 dark theme — toggle click handler + body-class sync.
     *
     * Attached via addEventListener (NOT inline onclick=) per dispatch
     * brief §0.3 #7 (CSP-clean pattern).
     *
     * Codex R1 Major #1 fix: keeps both `html.dark` AND `body.dark` in
     * sync. The head FOUC script runs before <body> exists so it can
     * only annotate <html>; this end-of-body script promotes the class
     * onto <body> so the brief §0.3 #6 `body.dark` contract holds for
     * any selector targeting body specifically (the paired
     * `html.dark, body.dark` rule in app.css already activates dark
     * tokens off either, but future selectors written per the locked
     * convention may target body alone).
     *
     * Click handler: toggles the class on BOTH <html> and <body>
     * synchronously, persists the new value to localStorage (try/catch
     * — storage may be unavailable), and updates the button's emoji +
     * aria-label.
     *
     * Initial-render reconciliation: the server-rendered button text
     * is 🌙 with aria-label "Switch to dark theme" (light is the
     * default). If the FOUC head script already applied html.dark
     * from localStorage, this script runs at parse-time and flips
     * the button to ☀️ before the operator interacts — a sub-frame
     * visual catch-up (acceptable V1; bank for V2 if operator
     * surfaces it).
     */
    (function () {
      var btn = document.getElementById('theme-toggle');
      if (!btn) return;
      var html = document.documentElement;
      var body = document.body;
      /* Initial sync (Codex R2 Minor #1 — two-way): mirror html.dark
       * onto body so the body.dark contract holds in either direction. */
      body.classList.toggle('dark', html.classList.contains('dark'));
      function applyToButton(isDark) {
        if (isDark) {
          btn.textContent = '☀️';  /* ☀️ sun */
          btn.setAttribute('aria-label', 'Switch to light theme');
        } else {
          btn.textContent = '🌙';  /* 🌙 moon */
          btn.setAttribute('aria-label', 'Switch to dark theme');
        }
      }
      applyToButton(html.classList.contains('dark'));
      btn.addEventListener('click', function () {
        var isDark = html.classList.toggle('dark');
        /* Keep body in sync so `body.dark` selectors stay valid. */
        body.classList.toggle('dark', isDark);
        var next = isDark ? 'dark' : 'light';
        try {
          window.localStorage.setItem('swing-trading-theme', next);
        } catch (e) {
          /* Storage unavailable — flip is session-only. */
        }
        applyToButton(isDark);
      });
    })();
  </script>
</body>
</html>
