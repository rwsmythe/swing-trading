{% extends "base.html.j2" %}
{% block title %}Process-grade trend — Swing Trading{% endblock %}
{% block content %}
<section class="metrics-process-grade-trend">
  <h1>Process-grade trend</h1>
  <p class="muted">
    Spec §4.8 — rolling-N closed-trades trend across process / entry /
    management / exit grades + disqualifying-violation rate + mistake-cost
    R. Grades render on a numeric encoding
    <strong>A=4, B=3, C=2, D=1, F=0</strong>. Per-trade markers always
    appear; the rolling line draws once the window has &ge;5 effective
    samples (spec §5.4 line band).
  </p>

  <p class="muted">
    Window size: N={{ vm.window_size }} | Closed-reviewed trades:
    {{ vm.per_trade_markers|length }}
  </p>

  {% if vm.per_trade_markers|length == 0 %}
  <p><em data-empty-state="process-grade-trend">No closed-reviewed trades to plot.</em></p>
  {% else %}

  {# Small-multiples: three scale-separated inline-SVG panels (OQ-1). Each
     series reads against a scale it belongs to — GRADES [0,4], RATE [0,1],
     COST [0,max] 0-anchored. The single overlay chart's incommensurability
     (a proportion + cost lines read against A=4..F=0) is fixed by separation,
     not restyling. _total stays table-only (OQ-3). #}

  <h2>Grades</h2>
  <svg viewBox="0 0 {{ vm.svg_width }} {{ vm.grades_svg_height }}"
       xmlns="http://www.w3.org/2000/svg"
       class="process-grade-trend-chart"
       width="{{ vm.svg_width }}"
       height="{{ vm.grades_svg_height }}"
       data-panel="grades">
    {# Axis labels per lesson #19 — grade numeric encoding visible inline. #}
    <g class="grade-axis-labels" data-marker="grade-axis-encoding">
      {% for value, label in vm.grade_axis_labels %}
      <text x="6"
            y="{{ vm.svg_margin_top + ((4.0 - value) / 4.0) * (vm.grades_svg_height - vm.svg_margin_top - vm.svg_margin_bottom) + 4 }}"
            class="muted">{{ label }}</text>
      {% endfor %}
    </g>
    {# Legend — names the 4 grade series. Swatch fill resolves through the
       metric-<name> CSS class (SVG presentation attrs cannot take var()).
       Swatches are <rect> (NEVER <polyline>, so the n=2 under-floor state
       still emits zero polylines). #}
    <g class="legend" data-marker="grades-legend">
      {% for series in vm.grade_series %}
      <rect class="process-grade-legend-swatch metric-{{ series.metric_name }}"
            x="{{ 360 + loop.index0 * 105 }}" y="6" width="10" height="10" />
      <text x="{{ 360 + loop.index0 * 105 + 14 }}" y="15"
            class="muted">{{ series.metric_name.split('_grade_')[0] }}</text>
      {% endfor %}
    </g>
    {# Per-trade markers — always rendered for trades with a grade letter. #}
    {% for marker in vm.per_trade_markers %}
      {% if marker.svg_y is not none %}
      <circle cx="{{ "%.2f"|format(marker.svg_x) }}"
              cy="{{ "%.2f"|format(marker.svg_y) }}"
              r="4"
              data-trade-id="{{ marker.trade_id }}"
              data-grade="{{ marker.process_grade_letter }}"
              data-disqualifying="{{ marker.disqualifying }}"
              class="process-grade-marker">
        <title>{{ marker.ticker }} ({{ marker.review_date }}) — grade {{ marker.process_grade_letter }} = {{ "%.1f"|format(marker.process_grade_numeric) }}</title>
      </circle>
      {% endif %}
    {% endfor %}
    {# The 4 grade rolling polylines — identical hook shape to the legacy
       template (preserves the route-test class + data-series). One <polyline>
       per contiguous non-None run so None gaps render as gaps (F-3). #}
    {% for series in vm.grade_series %}
      {% if series.is_drawable %}
        {% for seg in series.svg_polyline_segments %}
        <polyline points="{{ seg }}"
                  fill="none"
                  stroke-width="1.5"
                  data-series="{{ series.metric_name }}"
                  class="process-grade-rolling-line metric-{{ series.metric_name }}" />
        {% endfor %}
      {% endif %}
    {% endfor %}
  </svg>

  <h2>Disqualifying-violation rate</h2>
  <svg viewBox="0 0 {{ vm.svg_width }} {{ vm.rate_svg_height }}"
       xmlns="http://www.w3.org/2000/svg"
       class="process-grade-trend-chart"
       width="{{ vm.svg_width }}"
       height="{{ vm.rate_svg_height }}"
       data-panel="rate">
    <g class="rate-axis-labels" data-marker="rate-axis">
      {% for y, text in vm.rate_axis_labels %}
      <text x="6" y="{{ "%.2f"|format(y) }}" class="muted">{{ text }}</text>
      {% endfor %}
    </g>
    {% for series in vm.rate_series %}
      {% if series.is_drawable %}
        {% for seg in series.svg_polyline_segments %}
        <polyline points="{{ seg }}"
                  fill="none"
                  stroke-width="1.5"
                  data-series="{{ series.metric_name }}"
                  class="process-grade-rolling-line metric-{{ series.metric_name }}" />
        {% endfor %}
      {% else %}
        <text class="muted" data-marker="rate-under-floor"
              x="{{ vm.svg_margin_left }}"
              y="{{ "%.2f"|format(vm.rate_svg_height / 2) }}">rolling line draws once the window has >=5 effective samples</text>
      {% endif %}
    {% endfor %}
  </svg>

  <h2>Mistake cost (R per trade)</h2>
  <svg viewBox="0 0 {{ vm.svg_width }} {{ vm.cost_svg_height }}"
       xmlns="http://www.w3.org/2000/svg"
       class="process-grade-trend-chart"
       width="{{ vm.svg_width }}"
       height="{{ vm.cost_svg_height }}"
       data-panel="cost">
    <g class="cost-axis-labels" data-marker="cost-axis">
      {% for y, text in vm.cost_axis_labels %}
      <text x="6" y="{{ "%.2f"|format(y) }}" class="muted">{{ text }}</text>
      {% endfor %}
    </g>
    {% for series in vm.cost_series %}
      {% if series.is_drawable %}
        {% for seg in series.svg_polyline_segments %}
        <polyline points="{{ seg }}"
                  fill="none"
                  stroke-width="1.5"
                  data-series="{{ series.metric_name }}"
                  class="process-grade-rolling-line metric-{{ series.metric_name }}" />
        {% endfor %}
      {% else %}
        <text class="muted" data-marker="cost-under-floor"
              x="{{ vm.svg_margin_left }}"
              y="{{ "%.2f"|format(vm.cost_svg_height / 2) }}">rolling line draws once the window has >=5 effective samples</text>
      {% endif %}
    {% endfor %}
    <text class="muted" data-marker="cost-axis-caption"
          x="{{ vm.svg_margin_left }}"
          y="{{ vm.cost_svg_height - 4 }}">mistake-cost running total in table below</text>
  </svg>

  <h2>Per-metric rolling window (most recent)</h2>
  <table class="metric-grid process-grade-trend-table">
    <thead>
      <tr>
        <th>Metric</th>
        <th>Class</th>
        <th>Value</th>
        <th>CI</th>
        <th>Cadence</th>
        <th>Window</th>
        <th>Confidence</th>
      </tr>
    </thead>
    <tbody>
      {% for series in vm.rolling_series %}
      <tr data-metric="{{ series.metric_name }}"
          data-suppressed="{{ '1' if series.is_suppressed else '0' }}">
        <td>{{ series.metric_name }}</td>
        <td>{{ series.underlying_class }}</td>
        {% if series.is_suppressed %}
        <td colspan="2">
          <em data-marker="suppressed-{{ series.metric_name }}">{{ series.suppressed_placeholder }}</em>
        </td>
        <td colspan="3"></td>
        {% else %}
        <td>{{ series.point_value_text or "—" }}</td>
        <td>
          {% if series.ci_lower_text and series.ci_upper_text %}
          [{{ series.ci_lower_text }}, {{ series.ci_upper_text }}]
          {% else %}<em>—</em>{% endif %}
        </td>
        <td>
          {% if series.drawability_text %}
          <span class="muted" data-marker="drawability-{{ series.metric_name }}">{{ series.drawability_text }}</span>
          {% else %}<em>—</em>{% endif %}
        </td>
        <td>
          {% if series.window_not_full_warning_text %}
          <span class="badge badge-warn"
                data-marker="window-warning-{{ series.metric_name }}">{{ series.window_not_full_warning_text }}</span>
          {% else %}<em>—</em>{% endif %}
        </td>
        <td>
          {% if series.confidence_floor_warning_text %}
          <span class="badge badge-warn"
                data-marker="floor-warning-{{ series.metric_name }}">{{ series.confidence_floor_warning_text }}</span>
          {% else %}<em>—</em>{% endif %}
        </td>
        {% endif %}
      </tr>
      {% endfor %}
    </tbody>
  </table>

  {% endif %}
</section>
{% endblock %}
