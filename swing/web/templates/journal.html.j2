{% extends "base.html.j2" %}
{# Phase 7 Sub-C C.6 — state badge replaces the legacy bare ``t.status``
   text column. The macro looks up the per-state display label internally
   (mirrors STATE_BADGE_LABELS in swing/web/view_models/trades.py), so the
   journal page does NOT need a per-trade VM to render the badge — Trade
   objects are passed straight from JournalVM.trades. #}
{% from "partials/state_badge.html.j2" import render as state_badge %}
{% block content %}
  <h1>Journal</h1>
  <nav class="period-selector">
    {# Period keys are rolling day-count approximations, not calendar months/quarters.
       Labels are renamed to avoid the semantic mismatch. #}
    {% set _labels = {'week': 'Last 7d', 'month': 'Last 30d', 'quarter': 'Last 90d', 'ytd': 'YTD', 'all': 'All'} %}
    {% for p in ('week','month','quarter','ytd','all') %}
      <a href="/journal?period={{ p }}" class="{{ 'active' if p == vm.period else '' }}">{{ _labels[p] }}</a>
    {% endfor %}
  </nav>
  <section class="stats">
    <div>Trades: {{ vm.stats.n_trades }}</div>
    <div>Win rate: {{ '%.1f' | format(vm.stats.win_rate * 100) }}%</div>
    <div>Expectancy: {{ '%.2f' | format(vm.stats.expectancy_r) }}R</div>
    <div>Total R: {{ '%.2f' | format(vm.stats.total_r) }}</div>
    <div>Streak: {{ vm.stats.current_streak }} {{ vm.stats.current_streak_kind }}</div>
  </section>
  <section class="flags">
    <h2>Behavioral flags</h2>
    <p class="hint">Computed over your full trade history (not the selected period).</p>
    {% for f in vm.flags %}
      <div><strong>{{ f.title }}</strong> &mdash; {{ f.detail }}</div>
    {% else %}
      <p>No flags.</p>
    {% endfor %}
  </section>
  <section class="trades">
    <h2>Trades ({{ vm.total_rows }})</h2>
    {# Phase 14 SB4 Slice 2 — rich per-trade listing. Sort controls in the
       <thead> are wired in Slice 3; the per-row chart thumbnail in Slice 4.
       Each <tr> is the include'd journal_row.html.j2 partial. #}
    <table id="journal-table">
      <thead>
        <tr>
          <th>Chart</th>
          <th>Ticker</th>
          <th>Entry</th>
          <th>State</th>
          <th>Open price</th>
          <th>Shares</th>
          <th>Total risk</th>
          <th>Closing price</th>
          <th>Final R</th>
          <th>Pattern</th>
          <th>A+ bucket</th>
          <th>Hypothesis</th>
        </tr>
      </thead>
      <tbody>
        {% for row in vm.rows %}
          {% include "partials/journal_row.html.j2" %}
        {% else %}
          <tr><td colspan="12">No trades in this period.</td></tr>
        {% endfor %}
      </tbody>
    </table>
    <nav class="pagination">
      {% set _qp = '&period=' ~ vm.period ~ '&page_size=' ~ vm.page_size %}
      {% if vm.page > 1 %}
        <a href="/journal?page={{ vm.page - 1 }}{{ _qp }}" rel="prev">Prev</a>
      {% endif %}
      <span class="page-indicator">Page {{ vm.page }}</span>
      {% if vm.has_next %}
        <a href="/journal?page={{ vm.page + 1 }}{{ _qp }}" rel="next">Next</a>
      {% endif %}
    </nav>
  </section>
{% endblock %}
