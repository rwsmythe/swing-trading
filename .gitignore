# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.venv/
venv/

# Swing app data (lives outside Drive folder, but cover stray files)
swing-data/
/data/
.superpowers/

# OS
.DS_Store
Thumbs.db

# Legacy — archived for reference but not tracked
reference/archive/
legacy/

# Reference materials (binaries not suited for git history)
reference/*.pdf
reference/*.docx
reference/*.xlsx
reference/*.gdoc
reference/images/

# Copowers session state (local to working checkout)
.copowers-session-*.json
.copowers-subagent-active

# Claude Code session artifacts (ignored by default; specific project-local
# subagent definitions ARE tracked via the negation rules below per Phase 13
# spec §A.7 + OQ-11 — "Definition file is COMMITTED to repo (not gitignored)
# so labeling sessions are reproducible").
.claude/*
!.claude/agents/
.claude/agents/*
!.claude/agents/*.md

# Pipeline outputs (regenerated each run; not tracked)
# Exception: exports/diagnostics/*.{csv,md} are committed as research ledger
# (per V2 OHLCV arc; negation rules below override the exports/ ignore).
exports/*
!exports/diagnostics
exports/diagnostics/*
!exports/diagnostics/*.csv
!exports/diagnostics/*.md
# Research-arc cohort substrates (operator-supplied inputs to research harnesses;
# tracked for reproducibility per Option D pattern_cohort_evaluator dispatch arc).
!exports/research
exports/research/*
!exports/research/cohorts
exports/research/cohorts/*
!exports/research/cohorts/*.csv
# Pattern cohort detection harness smoke artifacts (per-iso timestamp dir; tracks
# the 2 small summary/manifest files per dir for traceability across bug-discovery
# iterations + cumulative substantive findings audit trail). results.csv is
# EXCLUDED — it is the per-verdict drill-down (~275 MB at 43,370 rows × 5 detector
# classes × 16 fields per V1; exceeds GitHub's 100 MB single-file limit). summary.md
# aggregates the headline tables + manifest.json captures metadata + skip-reason
# distribution; together these preserve substantive audit trail without LFS.
# Mirrors the exports/diagnostics/ tracking pattern (csv + md tracked there because
# diagnostic outputs are smaller; pattern_cohort outputs are larger per-verdict).
!exports/research/pattern-cohort-detection-*
exports/research/pattern-cohort-detection-*/*
!exports/research/pattern-cohort-detection-*/summary.md
!exports/research/pattern-cohort-detection-*/manifest.json

# Broker statements (personal financial data)
thinkorswim/

# Finviz evaluator A/B-test artifacts (diagnostic; regenerated on demand)
tests/fixtures/finviz/suggested-diffs-*.yaml

# Research harness smoke-test output (regenerated; not tracked)
research/harness/*/smoke-out/

# Pytest / orchestrator scratch directories (regenerated; not tracked).
# Covers per-phase (.tmp-phase4/ etc.) and per-verify (.tmp-orchestrator-verify/,
# .tmp-mathtext-verify/, .tmp-manual/, etc.) variants under one glob.
.tmp-*/

# Bulk reference artifacts (operator-local-only per phase3e-todo 2026-05-13
# "Minervini + body-of-knowledge reference review" entry tracking-decision).
# Source-of-truth curated extracts at reference/methodology/ ARE tracked
# (small + hand-curated). The bulk PDF + pymupdf4llm-converted MD + figures
# stay local-only (~110 MB combined) — too large + too auto-generated for
# repo tracking; review-dispatches consume operator's local copy.
reference/Books/
reference/minervini/

# Saved Schwab Developer Portal HTML pages (~2.4 MB; operator-local-only).
# Distilled markdown at reference/schwab-api/ IS tracked — small, hand-curated
# extract of the same content for use in integration dispatches.
reference/SchwabAPI/

# Schwab per-env tokens DBs (managed by schwabdev; plaintext OAuth state V1)
swing-data/schwab-tokens.*.db
swing-data/schwab-tokens.*.db-journal
swing-data/schwab-tokens.*.db-shm
swing-data/schwab-tokens.*.db-wal

# Schwab API audit DB backups (created pre-migration by _apply_migration runner)
swing-pre-phase11-schwab-migration-*.db
