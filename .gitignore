# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.venv/
venv/

# Swing app data (lives outside Drive folder, but cover stray files)
swing-data/
/data/
.superpowers/

# OS
.DS_Store
Thumbs.db

# Legacy — archived for reference but not tracked
reference/archive/
legacy/

# Reference materials (binaries not suited for git history)
reference/*.pdf
reference/*.docx
reference/*.xlsx
reference/*.gdoc
reference/images/

# Copowers session state (local to working checkout)
.copowers-session-*.json
.copowers-subagent-active

# Claude Code session artifacts
.claude/

# Pipeline outputs (regenerated each run; not tracked)
exports/

# Broker statements (personal financial data)
thinkorswim/

# Finviz evaluator A/B-test artifacts (diagnostic; regenerated on demand)
tests/fixtures/finviz/suggested-diffs-*.yaml

# Research harness smoke-test output (regenerated; not tracked)
research/harness/*/smoke-out/

# Pytest / orchestrator scratch directories (regenerated; not tracked).
# Covers per-phase (.tmp-phase4/ etc.) and per-verify (.tmp-orchestrator-verify/,
# .tmp-mathtext-verify/, .tmp-manual/, etc.) variants under one glob.
.tmp-*/

# Bulk reference artifacts (operator-local-only per phase3e-todo 2026-05-13
# "Minervini + body-of-knowledge reference review" entry tracking-decision).
# Source-of-truth curated extracts at reference/methodology/ ARE tracked
# (small + hand-curated). The bulk PDF + pymupdf4llm-converted MD + figures
# stay local-only (~110 MB combined) — too large + too auto-generated for
# repo tracking; review-dispatches consume operator's local copy.
reference/Books/
reference/minervini/

# Saved Schwab Developer Portal HTML pages (~2.4 MB; operator-local-only).
# Distilled markdown at reference/schwab-api/ IS tracked — small, hand-curated
# extract of the same content for use in integration dispatches.
reference/SchwabAPI/
